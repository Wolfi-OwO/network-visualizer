{
  "name": "routing-visualizer-backend",
  "version": "2.4.1",
  "scripts": {
    "dev": "nodemon --watch src --watch server.ts --ext ts --exec \"tsx server.ts\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "fill-demo-data": "node --import ./register-tsnode.mjs src/db/fill-demo-data.ts",
    "test": "cross-env TS_NODE_TRANSPILE_ONLY=true AUTHJWT_VERIFY=false LOG_LEVEL=error MONGODB_CONNECTION_STRING=mongodb://127.0.0.1:50000/team_a c8 --reporter html --reporter text-summary --reporter json-summary --reporter lcov mocha tests --recursive --timeout 10000 --exit",
    "test-ci": "cross-env TS_NODE_TRANSPILE_ONLY=true AUTHJWT_VERIFY=false LOG_LEVEL=error c8 --reporter cobertura --reporter text-summary mocha tests --recursive --timeout 10000 --exit --reporter mocha-junit-reporter"
  },
  "dependencies": {
    "@godaddy/terminus": "^4.12.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.2",
    "tsx": "^4.23.0",
    "uuid": "^9.0.0",
    "winston": "^3.19.0"
  },
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.43",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "c8": "^11.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "mocha": "^11.7.6",
    "mocha-junit-reporter": "^2.2.1",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.0.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.59.2"
  }
}
