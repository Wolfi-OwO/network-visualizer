# ── Backend configuration (all values are read in src/config/index.ts) ─────────

# Interface/hostname the server binds to (0.0.0.0 = all interfaces)
HOST=0.0.0.0

# HTTP port the API listens on
PORT=8080

# Runtime environment: development | production
NODE_ENV=development

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/netviz

# Drop & recreate the database on startup (true = clean slate, re-seed demo data)
DB_RECREATE=false

# Optional explicit CORS allow-list (comma-separated origins).
# Leave empty to allow localhost / 127.0.0.1 on any port by default.
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# Max accepted JSON request body size
JSON_BODY_LIMIT=8mb

# ── Auth ───────────────────────────────────────────────────────────────────────
# Secret used to sign session JWTs — generate your own, e.g. `openssl rand -hex 32`
# (production refuses to start with a missing/short value; never commit a real one)
JWT_SECRET=
# Session lifetime
JWT_TTL=1d
# Allow the password-less local login (defaults to true outside production)
ALLOW_DEV_LOGIN=true
# Require sign-in for all topology data (disables the shared anonymous workspace)
REQUIRE_AUTH=false
# Audit-log retention in days (entries auto-expire via a TTL index)
AUDIT_RETENTION_DAYS=90

# The OAuth redirect URI is derived from the URL the app is reached at, so
# register <your public URL>/auth/<provider>/callback with each provider.

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Add this exact Authorized redirect URI:  http://localhost:8080/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth — register an app at https://entra.microsoft.com (App registrations)
# Add this exact Redirect URI:  http://localhost:8080/auth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
