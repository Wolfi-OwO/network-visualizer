# ── Backend configuration (all values are read in src/config/index.ts) ─────────

# Interface/hostname the server binds to (0.0.0.0 = all interfaces)
HOST=0.0.0.0

# HTTP port the API listens on
PORT=8080

# Runtime environment: development | production
NODE_ENV=development

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/netviz

# Drop & recreate the database on startup (true = clean slate, re-seed demo data)
DB_RECREATE=false

# Optional explicit CORS allow-list (comma-separated origins).
# Leave empty to allow localhost / 127.0.0.1 on any port by default.
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# Max accepted JSON request body size
JSON_BODY_LIMIT=8mb
