# ── Backend configuration (all values are read in src/config/index.ts) ─────────

# Interface/hostname the server binds to (0.0.0.0 = all interfaces)
HOST=0.0.0.0

# HTTP port the API listens on
PORT=8080

# Runtime environment: development | production
NODE_ENV=development

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/netviz

# Drop & recreate the database on startup (true = clean slate, re-seed demo data)
DB_RECREATE=false

# Optional explicit CORS allow-list (comma-separated origins).
# Leave empty to allow localhost / 127.0.0.1 on any port by default.
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# Max accepted JSON request body size
JSON_BODY_LIMIT=8mb

# ── Auth ───────────────────────────────────────────────────────────────────────
# Secret used to sign session JWTs (use a long random string in production)
JWT_SECRET=106Tr6YLkf0tzECxWOykeq7cftmem36d5DDb5ZdbaDlm3XA9netw8p1oHll2AnuFX40PLOIi1PFZbJPtKhMcke
# Session lifetime
JWT_TTL=1d
# Where the API (and, in this setup, the SPA) is served. The frontend is built
# into the backend image and served from the same origin, so one URL is enough.
API_URL=http://localhost:8080
# Where users land after sign-in. Leave blank to reuse API_URL (single origin).
# Only set this if you run the frontend on a different origin (e.g. Vite :5173).
APP_URL=
# Allow the password-less local login (defaults to true outside production)
ALLOW_DEV_LOGIN=true

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${API_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth — register an app at https://entra.microsoft.com (App registrations)
# Redirect URI: ${API_URL}/api/auth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
